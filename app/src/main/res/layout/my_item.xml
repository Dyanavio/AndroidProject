<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:padding="7dp">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/logoImageView"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"/>

    <TextView
        android:id="@+id/nameTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:singleLine="true"
        android:textSize="20sp"
        app:layout_constraintHorizontal_bias="0.011"
        app:layout_constraintLeft_toRightOf="@id/logoImageView"
        app:layout_constraintRight_toLeftOf="@id/mutedImageView"
        app:layout_constraintTop_toTopOf="@id/logoImageView" />

    <ImageView
        android:id="@+id/mutedImageView"
        app:layout_constraintTop_toTopOf="@id/nameTextView"
        app:layout_constraintBottom_toBottomOf="@id/nameTextView"
        app:layout_constraintRight_toLeftOf="@id/verifiedImageView"
        android:src="@drawable/sound_off_icon"
        android:layout_marginEnd="10dp"
        android:layout_width="20dp"
        android:layout_height="20dp"/>

    <ImageView
        android:id="@+id/verifiedImageView"
        app:layout_constraintTop_toTopOf="@id/nameTextView"
        app:layout_constraintBottom_toBottomOf="@id/nameTextView"
        app:layout_constraintRight_toLeftOf="@id/timeTextView"
        android:src="@drawable/verified"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginEnd="5dp"/>

    <TextView
        android:id="@+id/timeTextView"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/nameTextView"
        app:layout_constraintTop_toTopOf="@id/logoImageView"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:layout_marginEnd="15dp"/>

    <ImageView
        android:id="@+id/lastUserImageView"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginLeft="10dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintBottom_toBottomOf="@id/logoImageView"
        app:layout_constraintLeft_toRightOf="@id/logoImageView" />

    <TextView
        android:id="@+id/lastMessageTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:textColor="#BCBCBC"
        android:textSize="15sp"
        android:ellipsize="end"
        android:maxLines="1"
        android:layout_marginEnd="10dp"
        app:layout_constraintBottom_toBottomOf="@id/unreadCounter"
        app:layout_constraintHorizontal_bias="0.076"
        app:layout_constraintLeft_toRightOf="@id/lastUserImageView"
        app:layout_constraintRight_toLeftOf="@id/unreadCounter"
        app:layout_constraintTop_toTopOf="@id/unreadCounter" />

    <TextView
        android:id="@+id/unreadCounter"
        android:layout_width="50dp"
        android:textAlignment="center"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_corners"
        android:textColor="@color/white"
        android:padding="10dp"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@id/lastUserImageView"
        app:layout_constraintRight_toRightOf="@id/timeTextView"/>


</androidx.constraintlayout.widget.ConstraintLayout>